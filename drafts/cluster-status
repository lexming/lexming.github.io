IFS='' read -r -d '' BANNER_BRUSSEL <<"EOF"
           [97;48;2;34;63;122m_   ___   _ ____ [0m
          [97;48;2;227;101;57m\[97;48;2;34;63;122m \ / / | | | __ )[0m
