#!/bin/bash
#
# Report status of all partitions in Slurm cluster
# including node state and used resources

VERSION="0.2"

BAR_BLOCK_FULL="█"
BAR_BLOCK_MIX="▒"
BAR_BLOCK_IDLE="░"
BAR_BLOCK_OFF="×"

RESOURCE_DISPLAY="usage"
WELLCOME_DISPLAY=0

IFS='' read -r -d '' BANNER_SOFIA <<"EOF"
         ○◎◎◎◎◎◎○      ◎◎◎◎◎◎○ 
